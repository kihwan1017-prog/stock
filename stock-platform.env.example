# stock-platform 비밀 환경변수 템플릿
# 복사 위치(권장): E:\StockTrading\secrets\stock-platform.env
# 프로젝트 참고: .env.example
#
# 사용법 (PowerShell):
#   New-Item -ItemType Directory -Force E:\StockTrading\secrets
#   Copy-Item .\stock-platform.env.example E:\StockTrading\secrets\stock-platform.env
#   notepad E:\StockTrading\secrets\stock-platform.env

APP_ENV=local
APP_NAME=stock-platform
APP_TIMEZONE=Asia/Seoul

# --- Database (필수) ---
DB_HOST=localhost
DB_PORT=5432
DB_NAME=stock_platform
DB_USER=stock_app
DB_PASSWORD=change-me
# Connection Pool (STEP58)
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800
DB_POOL_PRE_PING=true

# --- JWT 인증 (Admin Web 로그인) ---
# 운영(APP_ENV=prod|production|staging): JWT_SECRET 필수 — 비어 있으면 기동 실패
# 개발(APP_ENV=local|dev|development): JWT_SECRET 비어 있고 JWT_DEV_AUTO_SECRET=true 이면
#   기동 시 임시 Secret을 자동 생성합니다 (재시작마다 달라져 기존 토큰 무효).
JWT_SECRET=
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30
JWT_DEV_AUTO_SECRET=true

# 사용자가 0명일 때만 최초 admin 생성 (한 번만)
AUTH_BOOTSTRAP_ADMIN_USERNAME=
AUTH_BOOTSTRAP_ADMIN_PASSWORD=

# --- 관리 API Key (스크립트용, 프론트 NEXT_PUBLIC 금지) ---
ADMIN_API_KEY=

# --- Broker / 기타는 .env.example 전체 목록 참고 ---
KIWOOM_USE_MOCK=true
KIWOOM_LIVE_ORDER_ENABLED=false
SCHEDULER_ENABLED=true
