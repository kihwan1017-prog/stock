APP_ENV=local
APP_NAME=stock-platform
APP_TIMEZONE=Asia/Seoul

DB_HOST=localhost
DB_PORT=5432
DB_NAME=stock_platform
DB_USER=stock_app
DB_PASSWORD=change-me
# STEP58 — Connection Pool
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800
DB_POOL_PRE_PING=true

# 키움 REST (모의투자 기본)
KIWOOM_APP_KEY=
KIWOOM_SECRET_KEY=
KIWOOM_USE_MOCK=true
KIWOOM_LIVE_ORDER_ENABLED=false
KIWOOM_TIMEOUT_SECONDS=10
KIWOOM_HTTP_TIMEOUT_SECONDS=10
KIWOOM_MAX_REQUESTS_PER_SECOND=5
KIWOOM_ACCOUNT_NUMBER=
# 로컬/모의에서는 false 권장 (mock WS handshake 실패·429 소음 방지)
KIWOOM_RECOVERY_START_WS=false
KIWOOM_RECOVERY_START_TRADING=false
KIWOOM_RECOVERY_START_SCHEDULER=true

# 키움 WebSocket
KIWOOM_WS_URL=
KIWOOM_WS_PATH=/api/dostk/websocket
KIWOOM_WS_EXECUTION_TYPE=00
KIWOOM_WS_RECONNECT_MIN_SECONDS=1
KIWOOM_WS_RECONNECT_MAX_SECONDS=30
KIWOOM_WS_MAX_CONSECUTIVE_FAILURES=8
KIWOOM_WS_PING_INTERVAL_SECONDS=20
KIWOOM_WS_PING_TIMEOUT_SECONDS=10
KIWOOM_ORDER_WS_URL=
KIWOOM_ORDER_WS_PATH=
KIWOOM_ORDER_WS_SUBSCRIBE_JSON=

UPBIT_BASE_URL=https://api.upbit.com
UPBIT_TIMEOUT_SECONDS=10
UPBIT_MAX_REQUESTS_PER_SECOND=8

OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen3.5:4b
OLLAMA_TIMEOUT_SECONDS=120
OLLAMA_TEMPERATURE=0.2
OLLAMA_KEEP_ALIVE=10m

DART_API_KEY=
DART_BASE_URL=https://opendart.fss.or.kr/api
DART_TIMEOUT_SECONDS=20

NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
NAVER_NEWS_BASE_URL=https://openapi.naver.com/v1/search/news.json
NAVER_NEWS_TIMEOUT_SECONDS=15

REALTIME_STRATEGY_MARKET_CODE=KRX
REALTIME_STRATEGY_SYMBOL=
STRATEGY_AUTO_DEPLOY_ENABLED=false
PAPER_STRATEGY_AUTO_STOP_ENABLED=false

# 알림 (선택)
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# STEP54 — Telegram Operations Center
TELEGRAM_OPS_ENABLED=false
TELEGRAM_OPS_POLL_INTERVAL_SECONDS=3
# 쉼표 구분. 비우면 TELEGRAM_CHAT_ID만 허용
TELEGRAM_ALLOWED_CHAT_IDS=
# INFO | WARN | CRITICAL
TELEGRAM_NOTIFICATION_LEVEL=INFO
APP_VERSION=1.0.0
SLACK_ENABLED=false
SLACK_WEBHOOK_URL=
DISCORD_ENABLED=false
DISCORD_WEBHOOK_URL=

# 관리 API 보호 (서버 전용 — 프론트 NEXT_PUBLIC 에 넣지 말 것)
# 운영(prod/staging): ADMIN_API_KEY 필수 (미설정 시 기동 실패, DEV_OPEN 제거됨)
# 로컬: 비워둘 수 있으나 require_admin 은 JWT admin 또는 키 필요
ADMIN_API_KEY=

# ---------------------------------------------------------------------------
# JWT 인증 (Admin Web 로그인)
# Secret은 E:\StockTrading\secrets\stock-platform.env 에만 두고 Git에 커밋하지 말 것
# ---------------------------------------------------------------------------
# 운영(prod): JWT_SECRET 필수
# 개발(local): JWT_SECRET 비어 있고 JWT_DEV_AUTO_SECRET=true 이면 기동 시 임시 Secret 생성
JWT_SECRET=
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30
JWT_DEV_AUTO_SECRET=true
# 사용자가 0명일 때만 최초 관리자 생성
AUTH_BOOTSTRAP_ADMIN_USERNAME=admin
AUTH_BOOTSTRAP_ADMIN_PASSWORD=q1w2e3r4R$

SCHEDULER_ENABLED=true
SCHEDULER_TIMEZONE=Asia/Seoul
SCHEDULER_CANDIDATE_HOUR=16
SCHEDULER_CANDIDATE_MINUTE=10
SCHEDULER_AI_HOUR=16
SCHEDULER_AI_MINUTE=30
SCHEDULER_POSITION_HOUR=17
SCHEDULER_POSITION_MINUTE=0
SCHEDULER_EXCHANGE_CODE=KRX
SCHEDULER_CANDIDATE_LIMIT=30
SCHEDULER_MINIMUM_SCORE=50
SCHEDULER_AI_LIMIT=10
SCHEDULER_POSITION_LIMIT=5
SCHEDULER_POLICY_ID=1
SCHEDULER_PORTFOLIO_VALUE=10000000
SCHEDULER_AVAILABLE_CASH=5000000
SCHEDULER_MINIMUM_AI_SCORE=70
SCHEDULER_MINIMUM_CONFIDENCE=0.5

# STEP53 — Position Exit Monitor (Polling)
POSITION_EXIT_MONITOR_ENABLED=true
POSITION_EXIT_MONITOR_INTERVAL_SECONDS=5
POSITION_EXIT_STOP_LOSS_RATIO=0.05
POSITION_EXIT_TAKE_PROFIT_RATIO=0.10
POSITION_EXIT_TRAILING_STOP_RATIO=0.03
POSITION_EXIT_RELATIVE_LOSS_RATIO=0.08
