APP_ENV=local
APP_NAME=stock-platform
APP_TIMEZONE=Asia/Seoul

DB_HOST=localhost
DB_PORT=5432
DB_NAME=stock_platform
DB_USER=stock_app
DB_PASSWORD=change-me

# 키움 REST (모의투자 기본)
KIWOOM_APP_KEY=
KIWOOM_SECRET_KEY=
KIWOOM_USE_MOCK=true
KIWOOM_LIVE_ORDER_ENABLED=false
KIWOOM_TIMEOUT_SECONDS=10
KIWOOM_HTTP_TIMEOUT_SECONDS=10
KIWOOM_MAX_REQUESTS_PER_SECOND=5
KIWOOM_ACCOUNT_NUMBER=
KIWOOM_RECOVERY_START_WS=true
KIWOOM_RECOVERY_START_TRADING=false
KIWOOM_RECOVERY_START_SCHEDULER=true

# 키움 WebSocket
KIWOOM_WS_URL=
KIWOOM_WS_PATH=/api/dostk/websocket
KIWOOM_WS_EXECUTION_TYPE=00
KIWOOM_WS_RECONNECT_MIN_SECONDS=1
KIWOOM_WS_RECONNECT_MAX_SECONDS=30
KIWOOM_WS_PING_INTERVAL_SECONDS=20
KIWOOM_WS_PING_TIMEOUT_SECONDS=10
KIWOOM_ORDER_WS_URL=
KIWOOM_ORDER_WS_PATH=
KIWOOM_ORDER_WS_SUBSCRIBE_JSON=

UPBIT_BASE_URL=https://api.upbit.com
UPBIT_TIMEOUT_SECONDS=10
UPBIT_MAX_REQUESTS_PER_SECOND=8

OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen3.5:4b
OLLAMA_TIMEOUT_SECONDS=120
OLLAMA_TEMPERATURE=0.2
OLLAMA_KEEP_ALIVE=10m

DART_API_KEY=
DART_BASE_URL=https://opendart.fss.or.kr/api
DART_TIMEOUT_SECONDS=20

NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
NAVER_NEWS_BASE_URL=https://openapi.naver.com/v1/search/news.json
NAVER_NEWS_TIMEOUT_SECONDS=15

REALTIME_STRATEGY_MARKET_CODE=KRX
REALTIME_STRATEGY_SYMBOL=
STRATEGY_AUTO_DEPLOY_ENABLED=false
PAPER_STRATEGY_AUTO_STOP_ENABLED=false

# 알림 (선택)
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
SLACK_ENABLED=false
SLACK_WEBHOOK_URL=

SCHEDULER_ENABLED=true
SCHEDULER_TIMEZONE=Asia/Seoul
SCHEDULER_CANDIDATE_HOUR=16
SCHEDULER_CANDIDATE_MINUTE=10
SCHEDULER_AI_HOUR=16
SCHEDULER_AI_MINUTE=30
SCHEDULER_POSITION_HOUR=17
SCHEDULER_POSITION_MINUTE=0
SCHEDULER_EXCHANGE_CODE=KRX
SCHEDULER_CANDIDATE_LIMIT=30
SCHEDULER_MINIMUM_SCORE=50
SCHEDULER_AI_LIMIT=10
SCHEDULER_POSITION_LIMIT=5
SCHEDULER_POLICY_ID=1
SCHEDULER_PORTFOLIO_VALUE=10000000
SCHEDULER_AVAILABLE_CASH=5000000
SCHEDULER_MINIMUM_AI_SCORE=70
SCHEDULER_MINIMUM_CONFIDENCE=0.5
