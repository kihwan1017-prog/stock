# 운영(production) 환경변수 템플릿 — STEP60
#
# 복사 위치 (권장):
#   E:\StockTrading\secrets\stock-platform.env
#
# 프로젝트 .env 에 두지 마세요. Git 커밋 금지.
# 로컬 개발은 루트 .env.example 을 참고하세요.

APP_ENV=production
APP_NAME=stock-platform
APP_TIMEZONE=Asia/Seoul
APP_VERSION=1.0.0-rc1
LOG_LEVEL=INFO

# Admin Web Origin 만 (localhost 단독 금지)
CORS_ALLOW_ORIGINS=https://admin.example.local

# --- Database ---
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=stock_platform
DB_USER=stock_app
DB_PASSWORD=CHANGE_ME_STRONG_DB_PASSWORD
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800
DB_POOL_PRE_PING=true

# --- JWT / Admin ---
JWT_SECRET=CHANGE_ME_LONG_RANDOM_SECRET
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30
JWT_DEV_AUTO_SECRET=false
ADMIN_API_KEY=CHANGE_ME_ADMIN_API_KEY
AUTH_BOOTSTRAP_ADMIN_USERNAME=admin
AUTH_BOOTSTRAP_ADMIN_PASSWORD=CHANGE_ME_BOOTSTRAP_ONCE

# --- Broker (키움) ---
KIWOOM_APP_KEY=
KIWOOM_SECRET_KEY=
KIWOOM_USE_MOCK=true
KIWOOM_LIVE_ORDER_ENABLED=false
KIWOOM_TIMEOUT_SECONDS=10
KIWOOM_HTTP_TIMEOUT_SECONDS=10
KIWOOM_MAX_REQUESTS_PER_SECOND=5
KIWOOM_ACCOUNT_NUMBER=
KIWOOM_RECOVERY_START_WS=false
KIWOOM_RECOVERY_START_TRADING=false
KIWOOM_RECOVERY_START_SCHEDULER=true

# --- Ollama ---
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen3.5:4b
OLLAMA_TIMEOUT_SECONDS=120
OLLAMA_TEMPERATURE=0.2
OLLAMA_KEEP_ALIVE=10m

# --- Telegram ---
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_OPS_ENABLED=false
TELEGRAM_OPS_POLL_INTERVAL_SECONDS=3
TELEGRAM_ALLOWED_CHAT_IDS=
TELEGRAM_NOTIFICATION_LEVEL=INFO
TELEGRAM_WEBHOOK_SECRET=

# --- Scheduler ---
SCHEDULER_ENABLED=true
SCHEDULER_TIMEZONE=Asia/Seoul
SCHEDULER_EXCHANGE_CODE=KRX

# --- Position Exit Monitor ---
POSITION_EXIT_MONITOR_ENABLED=true
POSITION_EXIT_MONITOR_INTERVAL_SECONDS=5

# Live 전환 전에는 아래를 절대 true 로 두지 마세요.
# KIWOOM_LIVE_ORDER_ENABLED=true
# KIWOOM_USE_MOCK=false
